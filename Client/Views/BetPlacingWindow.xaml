    <!--
    /**
     * @file BetPlacingWindow.xaml
     * @brief View responsible for handling player bet placement UI.
     *
     * @details
     * This view is bound to the BetPlacingViewModel and provides the interface
     * for users to:
     * - View their current balance
     * - Adjust bet amounts using preset increments
     * - Reset or maximize bets
     * - Confirm and submit a bet
     * - Navigate back to the main menu
     *
     * Layout:
     * - Uses a Viewbox for responsive scaling across resolutions
     * - Background uses a gameboard image for visual consistency
     * - Canvas is used for absolute positioning of UI elements
     *
     * Data Bindings:
     * - CurrentBet → Displays the player's current bet amount
     * - PlayerMoney → Displays the player's available balance
     *
     * Commands:
     * - IncBetBy10Command / IncBetBy20Command / IncBetBy50Command / IncBetBy100Command
     *   → Increment bet values using chip-style buttons
     * - MaxBetCommand → Sets bet to maximum available balance
     * - ResetBetCommand → Resets bet to zero
     * - ConfirmBetCommand → Sends bet to server and proceeds to gameplay
     * - MainMenuCommand → Returns user to main menu
     *
     * UI Notes:
     * - Chip buttons are styled using Ellipse-based ControlTemplates
     *   to simulate casino chips
     * - Action buttons use bordered templates with hover/press effects
     *
     * Dependencies:
     * - Requires DataContext to be set to BetPlacingViewModel
     *
     * @author Matthew Romano
     * @date April 8th, 2026
     */
    -->
    
    <UserControl x:Class="Client.Views.BetPlacingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Viewbox Stretch="Uniform">
        <Grid Width="1300" Height="720">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="194*"/>
                <ColumnDefinition Width="11*"/>
                <ColumnDefinition Width="445*"/>
            </Grid.ColumnDefinitions>
            <Grid.Background>
                <ImageBrush
                    ImageSource="/ClientAssets/Gameboard.jpg"
                    Stretch="Fill" />
            </Grid.Background>
            <Canvas Background="Transparent" Grid.ColumnSpan="3">
                <Rectangle Width="130" Height="37" Fill="White" HorizontalAlignment="Left" VerticalAlignment="Center" Stroke="Black" StrokeThickness="2" />
                <Rectangle Canvas.Left="550" Canvas.Top="362" Width="200" Height="37" Fill="White"
                           Stroke="Black" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                <TextBlock Name="Bet" FontSize="14" Text="{Binding CurrentBet, StringFormat=Current Bet: ${0}}" Canvas.Left="606" Canvas.Top="372" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                <TextBlock Name="Balance" FontSize="14" Text="{Binding PlayerMoney, StringFormat=Balance: ${0}}" Canvas.Left="16" Canvas.Top="9" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,40">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                        />
                </StackPanel>

                <Button Content="Main Menu"
                    Width="147" Command="{Binding MainMenuCommand}"
                    Height="37"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="#000000"
                    Background="#FFFFFF"
                    BorderBrush="#000000"
                    BorderThickness="2"
                    Cursor="Hand" HorizontalAlignment="Left" 
                    Canvas.Left="1153" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="65" Height="65"
                            Command="{Binding IncBetBy50Command}"
                            Content="$50"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Cursor="Hand" HorizontalAlignment="Center" Canvas.Left="660" Canvas.Top="409" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Grid>
                                <Ellipse Fill="#E53935" Stroke="White" StrokeThickness="5"/>
                                <Ellipse Margin="10" Stroke="White" StrokeThickness="3" StrokeDashArray="2 2"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="65" Height="65"
                            Command="{Binding IncBetBy100Command}"
                            Content="$100"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Cursor="Hand" HorizontalAlignment="Center" Canvas.Left="740" Canvas.Top="409" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Grid>
                                <Ellipse Fill="#212121" Stroke="#FFD54F" StrokeThickness="5"/>
                                <Ellipse Margin="10" Stroke="#FFD54F" StrokeThickness="3" StrokeDashArray="2 2"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="65" Height="65"
                            Command="{Binding IncBetBy20Command}"
                            Content="$20"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Cursor="Hand" Click="Button_Click" HorizontalAlignment="Center" Canvas.Left="580" Canvas.Top="409" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Grid>
                                <Ellipse Fill="#43A047" Stroke="White" StrokeThickness="5"/>
                                <Ellipse Margin="10" Stroke="White" StrokeThickness="3" StrokeDashArray="2 2"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="65" Height="65" Command="{Binding IncBetBy10Command}"
                            Content="$10"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Cursor="Hand" HorizontalAlignment="Center" Canvas.Left="500" Canvas.Top="409" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Grid>
                                <Ellipse Fill="#1E88E5" Stroke="White" StrokeThickness="5"/>
                                <Ellipse Margin="10" Stroke="White" StrokeThickness="3" StrokeDashArray="2 2"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="115" Height="35"
                            Command="{Binding MaxBetCommand}"
                            Content="MAX BET"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="Black"
                            Background="#FFD54F"
                            BorderBrush="White"
                            BorderThickness="3"
                            Cursor="Hand" HorizontalAlignment="Center" Canvas.Left="470" Canvas.Top="484" VerticalAlignment="Top" Click="Button_Click_2">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="maxBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="16">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="maxBorder" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="116" Height="35"
                            Command="{Binding ResetBetCommand}"
                            Content="RESET BET"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="Black"
                            Background="#8B0000"
                            BorderBrush="White"
                            BorderThickness="3"
                            Cursor="Hand" Click="Button_Click_1" HorizontalAlignment="Center" Canvas.Left="714" Canvas.Top="484" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="resetBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="16">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="resetBorder" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="116" Height="35"
                            Command="{Binding ConfirmBetCommand}"
                            Content="PLACE BET"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="Black"
                            Background="#229A22"
                            BorderBrush="White"
                            BorderThickness="3"
                            Cursor="Hand" HorizontalAlignment="Center" Canvas.Left="592" Canvas.Top="484" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="maxBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="16">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="maxBorder" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            

            </Canvas>
        </Grid>
    </Viewbox>
</UserControl>