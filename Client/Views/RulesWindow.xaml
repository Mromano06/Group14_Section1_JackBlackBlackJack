<UserControl x:Class="Client.Views.RulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">

    <Viewbox Stretch="Uniform">
        <Grid Width="1300" Height="720">
            <Grid.Background>
                <ImageBrush ImageSource="/Assets/Gameboard.jpg" Stretch="Fill"/>
            </Grid.Background>

            <Canvas Background="Transparent">

                <!-- Title background -->
                <Rectangle Canvas.Left="400" Canvas.Top="30"
                           Width="500" Height="70"
                           RadiusX="12" RadiusY="12"
                           Fill="White"/>

                <TextBlock Canvas.Left="520" Canvas.Top="45"
                           FontSize="34"
                           FontWeight="Bold"
                           Text="Blackjack Rules"/>

                <!-- Main rules panel -->
                <Border Canvas.Left="180" Canvas.Top="130"
                        Width="940" Height="500"
                        Background="#F5F5F5"
                        BorderBrush="Black"
                        BorderThickness="2"
                        CornerRadius="15">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="25">

                            <TextBlock FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"
                                       Text="Objective"/>
                            <TextBlock FontSize="16"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,20"
                                       Text="Beat the dealer by getting closer to 21 without going over. If your hand goes above 21, you bust and lose the round."/>

                            <TextBlock FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"
                                       Text="Deck Setup"/>
                            <TextBlock FontSize="16"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,20"
                                       Text="This game uses a three-deck shoe. The shoe is reshuffled and reset before every hand."/>

                            <TextBlock FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"
                                       Text="Card Values"/>
                            <TextBlock FontSize="16"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,20"
                                       Text="Number cards are worth their face value. Jacks, Queens, and Kings are worth 10. Aces count as 1 or 11, whichever helps the hand most."/>

                            <TextBlock FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"
                                       Text="Player Actions"/>
                            <TextBlock FontSize="16"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"
                                       Text="• Hit: Take another card."/>
                            <TextBlock FontSize="16"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"
                                       Text="• Stand: Keep your current total and end your turn."/>
                            <TextBlock FontSize="16"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"
                                       Text="• Double Down: Double your bet, take exactly one more card, and end your turn."/>
                            <TextBlock FontSize="16"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,20"
                                       Text="• Split: Not currently implemented, but may be added later. In standard Blackjack, splitting is used when the first two cards have the same value."/>

                            <TextBlock FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"
                                       Text="Dealer Rules"/>
                            <TextBlock FontSize="16"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,20"
                                       Text="The dealer must hit on 16 or less and stand on 17 or more."/>

                            <TextBlock FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"
                                       Text="Winning"/>
                            <TextBlock FontSize="16"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"
                                       Text="• If you bust, you lose."/>
                            <TextBlock FontSize="16"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"
                                       Text="• If the dealer busts, you win."/>
                            <TextBlock FontSize="16"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"
                                       Text="• If your total is higher than the dealer’s, you win."/>
                            <TextBlock FontSize="16"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"
                                       Text="• If the dealer’s total is higher, you lose."/>
                            <TextBlock FontSize="16"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,20"
                                       Text="• If both totals are the same, the result is a push and your bet is returned."/>

                            <TextBlock FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"
                                       Text="Blackjack"/>
                            <TextBlock FontSize="16"
                                       TextWrapping="Wrap"
                                       Text="A Blackjack is an Ace plus any 10-value card on the initial deal, for a total of 21."/>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Back button -->
                <Button x:Name="BackButton"
                        Canvas.Left="575"
                        Canvas.Top="650"
                        Width="150"
                        Height="45"
                        FontSize="18"
                        FontWeight="Bold"
                        Content="Back"/>
            </Canvas>
        </Grid>
    </Viewbox>
</UserControl>