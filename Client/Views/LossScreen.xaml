<!--
/**
 * @file LossScreen.xaml
 * @brief View displayed when the player loses the game.
 *
 * @details
 * This view presents a full-screen background image representing a loss state.
 * It is bound to the LossScreenViewModel and relies on a single property.
 *
 * Layout:
 * - Uses a Grid with an ImageBrush background
 * - Image scales to fill the screen while maintaining aspect ratio
 *
 * Data Bindings:
 * - LossImagePath → Provides the image displayed as the background
 *
 * UI Behavior:
 * - No interactive elements are present
 *
 * MVVM Notes:
 * - Purely visual view with no direct logic
 * - All behavior is controlled by the ViewModel
 *
 * Dependencies:
 * - Requires DataContext to be set to LossScreenViewModel
 *
 * @author Matthew Romano
 * @date April 8th, 2026
 */
-->

<UserControl x:Class="Client.Views.LossScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Client.Views"
        mc:Ignorable="d">
    <Grid>
        <Grid.Background>
            <ImageBrush
            ImageSource="{Binding LossImagePath}"
            Stretch="UniformToFill" />
        </Grid.Background>

        <Button Content="Main Menu"
        Width="200"
        Height="100"
        Command="{Binding ContinueCommand}"
        FontSize="28"
        FontWeight="Bold"
        Foreground="#000000"
        Background="#FFFFFF"
        BorderBrush="#000000"
        BorderThickness="2"
        Cursor="Hand"
        HorizontalAlignment="Center"
        VerticalAlignment="Bottom"
        Margin="0,0,0,50">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                     Background="{TemplateBinding Background}"
                     BorderBrush="{TemplateBinding BorderBrush}"
                     BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
