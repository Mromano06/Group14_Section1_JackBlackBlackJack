<UserControl x:Class="Client.Views.GameplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Client.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:GameplayViewModel}">
    <Viewbox Stretch="Uniform">
        <Grid Width="1300" Height="720">
            <Grid.Background>
                <ImageBrush
                    ImageSource="/Assets/Gameboard.jpg"
                    Stretch="Fill" />
            </Grid.Background>
            <Canvas Background="Transparent">
                <Rectangle Width="110" Height="37" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Stroke="Black" StrokeThickness="2" />
                <Rectangle Width="128" Height="37" Fill="White" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="108" Stroke="Black" StrokeThickness="2"/>
                <Rectangle Canvas.Left="588" Canvas.Top="394" Width="124" Height="37" Fill="White" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <Button x:Name="Hit" Width="50" Height="50" Canvas.Left="564" Command="{Binding HitCommand}"
                Canvas.Top="454" FontSize="13" FontWeight="Bold" Content="Hit" HorizontalAlignment="Center" VerticalAlignment="Top"></Button>
                <Button x:Name="Stand" Width="50" Height="50" Canvas.Left="624" Command="{Binding StandCommand}"
                Canvas.Top="454" FontSize="13" FontWeight="Bold" Content="Stand" HorizontalAlignment="Center" VerticalAlignment="Top"></Button>
                <Button x:Name="Double" Width="50" Height="50" FontSize="12" Command="{Binding DoubleDownCommand}"
                FontWeight="Bold" Content="Double" Canvas.Left="684" Canvas.Top="454" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                <TextBlock Name="Instructions" FontSize="14" Text="It is your turn!" Canvas.Left="607" Canvas.Top="403" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock Name="Balance" FontSize="14" Text="{Binding PlayerMoney, StringFormat=Balance: ${0}}" Canvas.Left="16" Canvas.Top="9" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock Name="Bet" FontSize="14" Text="{Binding BetAmount, StringFormat=Current Bet: ${0}}" Canvas.Left="120" Canvas.Top="9" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                <ItemsControl ItemsSource="{Binding DealtDealerCards}" Width="192" Height="306" Margin="4">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                            <Image Source="{Binding CardImagePath}" Width="192" Height="306" Margin="4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                <ItemsControl ItemsSource="{Binding DealtPlayerCards}" Width="192" Height="306" Margin="4">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Image Source="{Binding CardImagePath}" Width="192" Height="306" Margin="4"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Canvas>
        </Grid>
    </Viewbox>

</UserControl>