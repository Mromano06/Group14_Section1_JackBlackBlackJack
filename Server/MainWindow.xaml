<!--
/**
 * @file MainWindow.xaml
 * @brief Main server UI window for displaying logs.
 *
 * @details
 * This window is the primary interface for the server application.
 * It provides a visual logging console where server events are
 * displayed in real-time.
 *
 * Layout:
 * - Root Grid containing a Canvas for absolute positioning
 * - Background image used for branding
 * - Header bar displaying application title
 * - ListBox used for dynamic log output
 *
 * UI Elements:
 * - Image: Displays JBLogger image in the background
 * - Rectangle: Acts as a header bar
 * - TextBlock: Displays the title of the log window
 * - ListBox: Displays server log messages
 *
 * Behavior:
 * - Log messages are appended dynamically via binding to the logger
 * - Scrollbars automatically appear when logs exceed visible space
 *
 * Notes:
 * - Uses Canvas for fixed positioning
 * - Designed primarily as a debug/logging interface
 *
 * @author Matthew Romano
 * @date April 2026
 */
-->

<Window x:Class="Server.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Server"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid>
        <Canvas Background="White">
            <Image Source="/Assets/JBLogger.png" Width="546" Height="467" Stretch="Uniform" Canvas.Left="127" Canvas.Top="-16" Opacity="0.4"/>
            <Rectangle Width="800" Height="27" Fill="White" HorizontalAlignment="Left" VerticalAlignment="Center" Stroke="Black"/>
            <TextBlock Name="Instructions" FontSize="14" Text="Server Logs - Jack Black Blackjack" Canvas.Left="297" 
                       Canvas.Top="4" HorizontalAlignment="Left" VerticalAlignment="Center" RenderTransformOrigin="0.495,0.604" ></TextBlock>
            <ListBox x:Name="LogListBox" 
                 Width="800" 
                 Height="423" 
                 Canvas.Left="0" 
                 Canvas.Top="27"
                 HorizontalAlignment="Left"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
        </Canvas>
    </Grid>
</Window>