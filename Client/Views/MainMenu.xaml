<!--
    /**
     * @file MainMenu.xaml
     * @brief Main menu view serving as the entry point of the application.
     *
     * @details
     * This view provides the primary navigation interface for the user.
     * It allows the player to:
     * - Start the game
     * - View the game rules
     * - Exit the application
     *
     * Layout:
     * - Uses a Viewbox for full-screen scaling across resolutions
     * - Background uses a themed image for visual consistency
     * - Grid layout with centered title and evenly spaced action buttons
     *
     * UI Structure:
     * - Title displayed prominently at the top of the screen
     * - Three large card-style buttons:
     *   • PLAY → Starts the game
     *   • RULES → Opens the rules screen
     *   • EXIT → Closes the application
     *
     * Data Bindings:
     * - PlayCommand → Navigates to the betting/game flow
     * - RulesCommand → Navigates to the rules screen
     * - ExitCommand → Terminates the application
     *
     * UI Behavior:
     * - Buttons are styled as playing cards using image backgrounds
     * - Rounded borders provide a polished, modern appearance
     * - Large button size improves usability and accessibility
     *
     * MVVM Notes:
     * - All navigation logic is handled through ICommand bindings
     * - No code-behind logic is required for interaction
     *
     * Dependencies:
     * - Requires DataContext to be set to MainMenuModel
     *
     * @author Matthew Romano
     * @date April 8th, 2026
     */
    -->

<UserControl x:Class="Client.Views.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Viewbox Stretch="UniformToFill">
        <Grid>
            <Grid.Background>
                <ImageBrush
                    ImageSource="/ClientAssets/MainMenu.png"
                    Stretch="Fill"/>
            </Grid.Background>

            <!-- Login input area: name + passcode with dark background panel -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="0,-60,0,0" Width="280"
                    Background="#CC000000" CornerRadius="12" Padding="16">
                <StackPanel>

                    <!-- Player Name -->
                    <TextBlock Text="Name"
                               Foreground="White" FontSize="14" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PlayerNameInput, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" Padding="6,4"
                             HorizontalAlignment="Stretch" Margin="0,0,0,12"
                             MaxLength="20"/>

                    <!-- Passcode -->
                    <TextBlock Text="Passcode"
                               Foreground="White" FontSize="14" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PasscodeInput, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" Padding="6,4"
                             HorizontalAlignment="Stretch" Margin="0,0,0,12"
                             MaxLength="10"/>

                    <!-- Status message pill (wrong passcode, connecting, etc.) -->
                    <Border Background="#DD1a1a1a" CornerRadius="6" Padding="8,6">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="Blue" FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"
                                   MinHeight="18"/>
                    </Border>

                </StackPanel>
            </Border>

            <Button Width="100" Height="150" Margin="556,454,556,30" Command="{Binding PlayCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="20"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            ClipToBounds="True">

                            <Grid>
                                <Image Source="/ClientAssets/BackOfCard.png" Stretch="Fill"/>

                                <TextBlock Text="PLAY"
                               Foreground="Black"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                            </Grid>

                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Width="100" Height="150" Margin="416,454,696,30" Command="{Binding ExitCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="20"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            ClipToBounds="True">

                            <Grid>
                                <Image Source="/ClientAssets/BackOfCard.png" Stretch="Fill"/>

                                <TextBlock Text="EXIT"
                                   Foreground="Black"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                            </Grid>

                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Width="100" Height="150" Margin="696,454,418,30" Command="{Binding RulesCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="20"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            ClipToBounds="True">

                            <Grid>
                                <Image Source="/ClientAssets/BackOfCard.png" Stretch="Fill"/>

                                <TextBlock Text="RULES"
                                   Foreground="Black"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                            </Grid>

                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </Grid>
    </Viewbox>

</UserControl>