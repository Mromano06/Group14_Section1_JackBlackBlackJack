<!--
/**
 * @file GameplayWindow.xaml
 * @brief Main gameplay view for the blackjack application.
 *
 * @details
 * This view represents the active gameplay screen where the player interacts
 * with the game. It is bound to the GameplayViewModel and reflects real-time
 * updates received from the server via the NetworkClient.
 *
 * Responsibilities:
 * - Display player and dealer hands dynamically
 * - Show current player balance and bet amount
 * - Provide gameplay controls (Hit, Stand, Double Down)
 * - Handle navigation back to the main menu
 *
 * Layout:
 * - Uses a Viewbox for responsive scaling across screen sizes
 * - Canvas-based layout for precise positioning of gameplay elements
 * - Background uses a gameboard image for consistent styling
 *
 * Data Bindings:
 * - PlayerMoney → Displays current player balance
 * - BetAmount → Displays current bet amount
 * - DealtPlayerCards → Observable collection of player cards
 * - DealtDealerCards → Observable collection of dealer cards
 * - AllowDouble → Controls availability of the double down button
 *
 * Commands:
 * - HitCommand → Requests a hit action from the server
 * - StandCommand → Ends the player’s turn
 * - DoubleDownCommand → Doubles bet and draws one final card
 * - MainMenuCommand → Navigates back to the main menu
 *
 * UI Behavior:
 * - Card displays use ItemsControl bound to observable collections
 *   to dynamically render cards as they are received
 * - Cards are visually overlapped using negative margins to mimic
 *   real card stacking
 * - Action buttons are styled as casino chips using Ellipse templates
 *
 * MVVM Notes:
 * - No direct game logic exists in this view
 * - All interactions are routed through ICommand bindings
 * - Real-time updates are driven by event subscriptions in GameplayViewModel
 *
 * Dependencies:
 * - Requires DataContext to be set to GameplayViewModel
 *
 * @author Matthew Romano
 * @date April 8th, 2026
 */
-->
    
<UserControl x:Class="Client.Views.GameplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Client.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:GameplayViewModel}">

    <Viewbox Stretch="Uniform">
        <Grid Width="1300" Height="720">
            <Grid.Background>
                <ImageBrush
                    ImageSource="/Assets/Gameboard.jpg"
                    Stretch="Fill" />
            </Grid.Background>
            <Canvas Background="Transparent">
                <Rectangle Width="150" Height="37" Fill="White" HorizontalAlignment="Left" VerticalAlignment="Center" Stroke="Black" StrokeThickness="2" />
                <Rectangle Width="150" Height="37" Fill="White" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="147" Stroke="Black" StrokeThickness="2"/>
                <Rectangle Canvas.Left="588" Canvas.Top="394" Width="124" Height="37" Fill="White" Stroke="Black" StrokeThickness="2" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock Name="Instructions" FontSize="14" Text="It is your turn!" Canvas.Left="607" Canvas.Top="403" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock Name="Balance" FontSize="14" Text="{Binding PlayerMoney, StringFormat=Balance: ${0}}" Canvas.Left="16" Canvas.Top="9" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock Name="Bet" FontSize="14" Text="{Binding BetAmount, StringFormat=Current Bet: ${0}}" Canvas.Left="163" Canvas.Top="9" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                <Button Width="68" Height="68"
                    Content="Hit" Command="{Binding HitCommand}"
                    FontSize="13"
                    FontWeight="Bold"
                    Foreground="White"
                    BorderThickness="6"
                    Cursor="Hand" Canvas.Left="616" Canvas.Top="445" HorizontalAlignment="Center" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse Fill="#C62828" Stroke="White" StrokeThickness="3"/>
                                <Ellipse Margin="12" Stroke="White" StrokeThickness="3" StrokeDashArray="2 2"/>
                                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Width="68" Height="68"
                    Content="Stand" Command="{Binding StandCommand}"
                    FontSize="11"
                    FontWeight="Bold"
                    Foreground="White"
                    BorderThickness="6"
                    Cursor="Hand" Canvas.Left="533" Canvas.Top="445" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse Fill="#212121" Stroke="#FFD54F" StrokeThickness="3"/>
                                <Ellipse Margin="12" Stroke="#FFD54F" StrokeThickness="3" StrokeDashArray="2 2"/>
                                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Width="68" Height="68"
                    Content="Double" Command="{Binding DoubleDownCommand}"
                    FontSize="9" IsEnabled="{Binding AllowDouble}"
                    FontWeight="Bold"
                    Foreground="White"
                    BorderThickness="6"
                    Cursor="Hand" 
                    Canvas.Left="699" Canvas.Top="445" HorizontalAlignment="Center" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse Fill="#0000FF" Stroke="#000000" StrokeThickness="3"/>
                                <Ellipse Margin="12" Stroke="#000000" StrokeThickness="3" StrokeDashArray="2 2"/>
                                <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Main Menu"
                    Width="147" Command="{Binding MainMenuCommand}"
                    Height="37"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="#000000"
                    Background="#FFFFFF"
                    BorderBrush="#000000"
                    BorderThickness="2"
                    Cursor="Hand" HorizontalAlignment="Left" 
                    Canvas.Left="1153" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <ItemsControl ItemsSource="{Binding DealtPlayerCards}"
                      Canvas.Top="526"
                      Width="394"
                      Height="138"
                      HorizontalAlignment="Left" Canvas.Left="582" VerticalAlignment="Center">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Image Source="{Binding CardImagePath}"
                           Width="85"
                           Height="128"
                           Margin="0,0,-45,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding DealtDealerCards}"
                    Canvas.Top="50"
                    Width="394"
                    Height="138"
                    HorizontalAlignment="Left" Canvas.Left="582" VerticalAlignment="Center">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Image Source="{Binding CardImagePath}"
                                Width="85"
                                Height="128"
                                Margin="0,0,-45,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>
            </Canvas>
        </Grid>
    </Viewbox>

</UserControl>