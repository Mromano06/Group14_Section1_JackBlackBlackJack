<!--
/**
 * @file ResultScreen.xaml
 * @brief View displayed after a round to show the round result.
 *
 * @details
 * This view presents the outcome of the most recent round and allows
    the player to either continue or return to the main menu.
 *
 * Responsibilities:
 * - Display the result message from the completed round
 * - Provide navigation options for continuing or exiting
 *
 * Layout:
 * - Uses a Viewbox for responsive scaling across screen sizes
 * - Background uses the gameboard image for consistency with gameplay
 * - Canvas is used for positioning result display elements
 *
 * Data Bindings:
 * - ResultMessage → Displays the outcome of the round (e.g., win, loss, push)
 *
 * Commands:
 * - ContinueCommand → Navigates to the betting screen for the next round
 * - MainMenuCommand → Navigates back to the main menu
 *
 * UI Behavior:
 * - Displays a centered result message inside a styled rectangle
 * - Provides two action buttons:
 *   • "Main Menu" for exiting the current game session
 *   • "Next Round" for continuing gameplay
 *
 * MVVM Notes:
 * - All actions are routed through ICommand bindings
 * - Navigation logic is handled entirely in the ResultScreenViewModel
 *
 * Dependencies:
 * - Requires DataContext to be set to ResultScreenViewModel
 *
 * @author Matthew Romano
 * @date April 8th, 2026
 */
-->

<UserControl x:Class="Client.Views.ResultScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Viewbox Stretch="Uniform">
        <Grid Width="1300" Height="720">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="41*"/>
                <ColumnDefinition Width="89*"/>
            </Grid.ColumnDefinitions>
            <Grid.Background>
                <ImageBrush
                    ImageSource="/ClientAssets/Gameboard.jpg"
                    Stretch="Fill" />
            </Grid.Background>
            <Canvas Background="Transparent" Grid.ColumnSpan="2">
                <Rectangle Canvas.Left="560" Canvas.Top="375" Width="180" Height="37" Stroke="Black" StrokeThickness="1" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                <TextBlock Name="Balance" FontSize="14" Text="{Binding ResultMessage}" Canvas.Left="580" Canvas.Top="385" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            </Canvas>

            <Button Content="Main Menu"
                    Width="95" Command="{Binding MainMenuCommand}"
                    Height="37"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="#000000"
                    Background="#FFFFFF"
                    BorderBrush="#000000"
                    BorderThickness="2"
                    Cursor="Hand" HorizontalAlignment="Left" 
                    Canvas.Left="1153" VerticalAlignment="Top" Margin="135,427,0,0" Grid.Column="1">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="Next Round"
                 Width="96" Command="{Binding ContinueCommand}"
                 Height="37"
                 FontSize="14"
                 FontWeight="Bold"
                 Foreground="#000000"
                 Background="#FFFFFF"
                 BorderBrush="#000000"
                 BorderThickness="2"
                 Cursor="Hand" HorizontalAlignment="Left" 
                 Canvas.Left="1153" VerticalAlignment="Top" Margin="250,427,0,0" Grid.Column="1">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                             Background="{TemplateBinding Background}"
                             BorderBrush="{TemplateBinding BorderBrush}"
                             BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </Grid>
    </Viewbox>
</UserControl>